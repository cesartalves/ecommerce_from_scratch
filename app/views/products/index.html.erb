<div class="products-container">  
<% @products.each do |product| %>
  <div class="products-card">
  <%= link_to product_path(product), class: "product-link" do %>
    <h3><%= product.name %></h3>
    <p><%= product.description %></p>

    <%= image_tag product.image if product.image.attached? %>

    <p class="price">R$ <%= product.price.to_s("f") %></p>
  <% end %>

  <%= button_to "Adicionar ao Carrinho",
        add_product_path(product_id: product.id),
        method: :post,
        class: "btn btn-primary w-100 mt-3 add-to-cart" %>
  </div>
<% end %>
</div>
