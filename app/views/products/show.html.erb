<main class="product-detail-page">
  <div class="container py-5">
    <article class="product-detail-card">
      <div class="product-detail-layout">
        <div class="product-detail-image-wrapper">
          <% if @product.image.attached? %>
            <%= image_tag @product.image,
                  class: "product-detail-image",
                  width: 220,
                  alt: @product.name %>
          <% else %>
            <div class="product-detail-image-placeholder">
              <span aria-hidden="true">&#128247;</span>
              <p>Imagem indisponível</p>
            </div>
          <% end %>
        </div>

        <div class="product-detail-content">
          <p class="product-detail-eyebrow">Peça para sua coleção</p>
          <h1 class="product-detail-title"><%= @product.name %></h1>

          <div class="product-detail-divider"></div>

          <p class="product-detail-description">
            <%= @product.description.presence || "Sem descrição disponível." %>
          </p>

          <div class="product-detail-purchase">
            <span class="product-detail-price-label">Preço</span>
            <p class="product-detail-price">
              <%= number_to_currency(@product.price,
                    unit: "R$ ",
                    separator: ",",
                    delimiter: ".") %>
            </p>

            <% if @product.in_stock? %>
              <%= button_to "Adicionar ao carrinho",
                    add_product_path(product_id: @product.id),
                    method: :post,
                    class: "btn btn-primary btn-lg w-100 add-to-cart" %>
            <% else %>
              <button class="btn btn-secondary btn-lg w-100" disabled>Produto esgotado</button>
            <% end %>

            <p class="product-detail-security-note mb-0">
              Compra segura e pagamento protegido
            </p>
          </div>
        </div>
      </div>
    </article>
  </div>
</main>
