<div class="container py-5">
  <h2 class="mb-4">🛒 Meu Carrinho</h2>

  <% if @order.line_items.empty? %>

    <div class="alert alert-info">
      Seu carrinho está vazio.
    </div>

    <%= link_to "Ver Produtos",
          products_path,
          class: "btn btn-primary" %>

  <% else %>

    <div class="card shadow-sm">
      <div class="card-body">

        <% @order.line_items.each do |line_item| %>
          <div class="row align-items-center py-3 border-bottom">

            <div class="col-md-5">
              <h5 class="mb-0">
                <%= line_item.product.name %>
              </h5>
            </div>

            <div class="col-md-3 text-center">
              <span class="fw-bold">
                <%= number_to_currency(line_item.price) %>
              </span>
            </div>

            <div class="col-md-4">
              <div class="d-flex justify-content-center align-items-center">

                <%= button_to remove_product_path(product_id: line_item.product.id),
                      method: :post,
                      class: "btn btn-outline-danger btn-sm" do %>
                  −
                <% end %>

                <span class="mx-3 fw-bold fs-5">
                  <%= line_item.quantity %>
                </span>

                <%= button_to add_product_path(product_id: line_item.product.id),
                      method: :post,
                      class: "btn btn-outline-success btn-sm" do %>
                  +
                <% end %>

              </div>
            </div>

          </div>
        <% end %>

      </div>
    </div>

    <div class="card shadow-sm mt-4">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center">

          <div>
            <h5 class="mb-0">Total do Pedido</h5>
          </div>

          <div>
            <h3 class="mb-0 text-primary">
              <%= number_to_currency(@order.total) %>
            </h3>
          </div>

        </div>
      </div>
    </div>

    <div class="mt-4 text-end">
      <%= link_to "Finalizar Pedido",
            checkout_path,
            class: "btn btn-lg btn-primary" %>
    </div>

  <% end %>
</div>