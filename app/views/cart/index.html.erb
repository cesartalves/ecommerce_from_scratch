<div class="container py-5">
  <h2 class="mb-4">🛒 Meu Carrinho</h2>

  <% if @order.line_items.empty? %>

    <div class="alert alert-info">
      Seu carrinho está vazio.
    </div>

    <%= link_to "Ver Produtos",
          products_path,
          class: "btn btn-primary" %>

  <% else %>

    <% if @unavailable_line_items.any? %>
      <div class="alert alert-warning" role="alert">
        Alguns itens não possuem estoque suficiente. Reduza ou remova as quantidades indicadas abaixo.
      </div>
    <% end %>

    <div class="card shadow-sm">
      <div class="card-body">

        <% @order.line_items.each do |line_item| %>
          <% unavailable = line_item.quantity > line_item.product.stock %>
          <div class="row align-items-center py-3 border-bottom">

            <div class="col-md-5">
              <div class="d-flex align-items-center gap-3">
                <%= link_to product_path(line_item.product), class: "cart-product-image", aria: { label: line_item.product.name } do %>
                  <% if line_item.product.image.attached? %>
                    <%= image_tag line_item.product.image, alt: line_item.product.name %>
                  <% else %>
                    <span aria-hidden="true">◇</span>
                  <% end %>
                <% end %>

                <div>
                  <h5 class="mb-0">
                    <%= link_to line_item.product.name, product_path(line_item.product), class: "cart-product-name" %>
                  </h5>
                  <% if unavailable %>
                    <small class="text-danger">Apenas <%= line_item.product.stock %> em estoque</small>
                  <% end %>
                </div>
              </div>
            </div>

            <div class="col-md-3 text-center">
              <span class="fw-bold">
                <%= number_to_currency(line_item.price) %>
              </span>
            </div>

            <div class="col-md-4">
              <div class="d-flex justify-content-center align-items-center">

                <%= button_to remove_product_path(product_id: line_item.product.id),
                      method: :post,
                      class: "btn btn-outline-danger btn-sm" do %>
                  −
                <% end %>

                <span class="mx-3 fw-bold fs-5">
                  <%= line_item.quantity %>
                </span>

                <%= button_to add_product_path(product_id: line_item.product.id),
                      method: :post,
                      disabled: line_item.quantity >= line_item.product.stock,
                      class: "btn btn-outline-success btn-sm" do %>
                  +
                <% end %>

              </div>
            </div>

          </div>
        <% end %>

      </div>
    </div>

    <div class="card shadow-sm mt-4">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center">

          <div>
            <h5 class="mb-0">Total do Pedido</h5>
          </div>

          <div>
            <h3 class="mb-0 text-primary">
              <%= number_to_currency(@order.total) %>
            </h3>
          </div>

        </div>
      </div>
    </div>

    <div class="mt-4 text-end">
      <% if @unavailable_line_items.empty? %>
        <%= link_to "Finalizar Pedido", checkout_path, class: "btn btn-lg btn-primary" %>
      <% else %>
        <button class="btn btn-lg btn-secondary" disabled>Revise o estoque para continuar</button>
      <% end %>
    </div>

  <% end %>
</div>
