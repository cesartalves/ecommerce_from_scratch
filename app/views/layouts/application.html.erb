<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Ecommerce From Scratch" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <body class="storefront-body">
    <nav class="navbar navbar-expand-lg storefront-navbar" aria-label="Navegação principal">
      <div class="container storefront-navbar__inner">
      <%= link_to root_path, class: "storefront-brand" do %>
        <span class="storefront-brand__mark">CC</span>
        <span>
          <strong>Cesar</strong>
          <small>Colecionismo</small>
        </span>
      <% end %>

      <button class="navbar-toggler" type="button"
            data-bs-toggle="collapse"
            data-bs-target="#storefrontNavigation"
            aria-controls="storefrontNavigation"
            aria-expanded="false"
            aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse" id="storefrontNavigation">
        <ul class="navbar-nav me-auto storefront-nav">
        <li class="nav-item">
          <%= link_to "Produtos", products_path, class: "nav-link" %>
        </li>

         <% if user_signed_in? %>
         <li class="nav-item">
            <%= link_to "Carrinho", cart_path, class: "nav-link" %></li>
            <li class="nav-item">
              <%= link_to "Meus Pedidos", orders_path, class: "nav-link" %>
            </li>
            <li class="nav-item">
              <%= link_to "Meu perfil", edit_user_registration_path, class: "nav-link" %>
            </li>
          <% else %>
            <li class="nav-item"><%= link_to "Entrar", new_user_session_path, class: "nav-link" %></li>
          <% end %>
        </ul>

        <%= search_form_for @q, url: products_path, method: :get,
            html: { class: "storefront-search", role: "search" } do |f| %>

          <%= f.search_field :name_or_description_cont,
                class: "form-control",
                placeholder: "Buscar no catálogo...",
                aria: { label: "Buscar produtos" } %>

          <%= f.submit "Buscar", class: "btn storefront-button storefront-button--secondary" %>
        <% end %>
      </div>
      </div>
    </nav>

    <main class="storefront-main">
      <div class="storefront-flashes container">
        <% flash.each do |type, message| %>
          <div class="storefront-flash storefront-flash--<%= type == "alert" ? "danger" : "success" %>" role="alert">
            <%= message %>
          </div>
        <% end %>
      </div>
      <%= yield %>
    </main>

    <footer class="storefront-footer">
      <div class="container">
        <span class="storefront-brand__mark">CC</span>
        <p><strong>Cesar Colecionismo</strong><br>Peças especiais para a sua coleção.</p>
      </div>
    </footer>
  </body>
</html>
