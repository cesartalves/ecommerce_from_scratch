<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-6">

      <div class="card shadow-sm">
        <div class="card-header">
          <h2 class="mb-0">Editar Meu Usuário</h2>
        </div>

        <div class="card-body">

          <%= render "devise/shared/error_messages", resource: resource %>

          <%= form_for(resource,
                as: resource_name,
                url: registration_path(resource_name),
                html: { method: :put }) do |f| %>

            <div class="mb-3">
              <%= f.label :name, "Nome completo", class: "form-label fw-bold" %>
              <%= f.text_field :name, autocomplete: "name", class: "form-control" %>
            </div>

            <div class="mb-3">
              <%= f.label :email, class: "form-label fw-bold" %>
              <%= f.email_field :email,
                    autofocus: true,
                    autocomplete: "email",
                    class: "form-control" %>
            </div>

            <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
              <div class="alert alert-warning">
                Aguardando confirmação para:
                <strong><%= resource.unconfirmed_email %></strong>
              </div>
            <% end %>

            <div class="mb-3">
              <%= f.label :password, "Nova senha", class: "form-label fw-bold" %>

              <div class="form-text mb-2">
                Deixe em branco se não quiser alterar sua senha.
              </div>

              <%= f.password_field :password,
                    autocomplete: "new-password",
                    class: "form-control" %>

              <% if @minimum_password_length %>
                <div class="form-text">
                  Mínimo de <%= @minimum_password_length %> caracteres.
                </div>
              <% end %>
            </div>

            <div class="mb-3">
              <%= f.label :password_confirmation,
                    "Confirmação da senha",
                    class: "form-label fw-bold" %>

              <%= f.password_field :password_confirmation,
                    autocomplete: "new-password",
                    class: "form-control" %>
            </div>

            <div class="mb-4">
              <%= f.label :current_password,
                    "Senha atual",
                    class: "form-label fw-bold" %>

              <div class="form-text mb-2">
                Precisamos da sua senha atual para confirmar as alterações.
              </div>

              <%= f.password_field :current_password,
                    autocomplete: "current-password",
                    class: "form-control" %>
            </div>

            <div class="d-flex gap-2">
              <%= f.submit "Salvar Alterações",
                    class: "btn btn-primary" %>

              <%= link_to "Voltar",
                    request.referer || root_path,
                    class: "btn btn-outline-secondary" %>
            </div>

          <% end %>

        </div>
      </div>

    </div>
  </div>
</div>
