<div class="container py-5">
  <h2 class="mb-4">Meus Pedidos</h2>

  <% if @orders.empty? %>
    <div class="alert alert-info">
      Você ainda não fez nenhum pedido.
    </div>

    <%= link_to "Ver produtos", products_path, class: "btn btn-primary" %>
  <% else %>
    <div class="row g-4">
      <% @orders.each do |order| %>
        <div class="col-12">
          <div class="card shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center">
              <div>
                <strong>Pedido #<%= order.id %></strong>
              </div>

              <span class="badge bg-secondary">
                <%= order_status_label(order) %>
              </span>
            </div>

            <div class="card-body">
              <% if order.waiting_payment? && (pix_payment = order.latest_pix_payment) %>
                <div class="mb-4 rounded border bg-light p-4 text-center">
                  <h5>Pagamento via PIX</h5>
                  <p class="text-muted">Escaneie o QR Code ou use o código copia e cola.</p>

                  <% if pix_payment.pix_qr_code_base64.present? %>
                    <%= image_tag "data:image/png;base64,#{pix_payment.pix_qr_code_base64}",
                          alt: "QR Code PIX do pedido ##{order.id}",
                          class: "img-fluid mb-3",
                          style: "max-width: 220px;" %>
                  <% end %>

                  <% if pix_payment.pix_qr_code.present? %>
                    <label class="form-label fw-bold" for="pix-code-<%= order.id %>">
                      PIX copia e cola
                    </label>
                    <input id="pix-code-<%= order.id %>"
                           class="form-control"
                           type="text"
                           value="<%= pix_payment.pix_qr_code %>"
                           readonly>
                  <% end %>
                </div>
              <% end %>

              <% order.line_items.each do |li| %>
                <div class="row align-items-center py-3 border-bottom">
                  <div class="col-md-2">
                    <% if li.product.image.attached? %>
                      <%= image_tag li.product.image,
                            class: "img-thumbnail",
                            style: "max-width: 80px;" %>
                    <% else %>
                      <div class="bg-light border rounded text-muted d-flex align-items-center justify-content-center"
                           style="width: 80px; height: 80px;">
                        Sem imagem
                      </div>
                    <% end %>
                  </div>

                  <div class="col-md-6">
                    <h5 class="mb-1">
                      <%= li.product.name %>
                    </h5>

                    <small class="text-muted">
                      Quantidade: <%= li.quantity %>
                    </small>
                  </div>

                  <div class="col-md-4 text-md-end">
                    <strong>
                      <%= number_to_currency(li.price) %>
                    </strong>
                  </div>
                </div>
              <% end %>

              <div class="d-flex justify-content-between align-items-center mt-4">
                <div>
                  <span class="fw-bold d-block">Total</span>
                  <% if order.shipping_service.present? %>
                    <small class="text-muted">
                      Frete Correios <%= order.shipping_service %>: <%= number_to_currency(order.shipping_cost) %>
                      <% if order.shipping_days.present? %>
                        · até <%= pluralize(order.shipping_days, "dia útil", "dias úteis") %>
                      <% end %>
                    </small>
                  <% end %>
                </div>

                <h4 class="mb-0 text-primary">
                  <%= number_to_currency(order.total) %>
                </h4>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
