<% content_for :title, "Editar produto" %>

<div class="admin-page-heading">
  <div>
    <span class="admin-eyebrow">Catálogo</span>
    <h1>Editar produto</h1>
    <p>Atualize as informações de <strong><%= @product.name %></strong>.</p>
  </div>
</div>

<section class="admin-panel admin-panel--form">
  <div class="admin-panel__header">
    <div>
      <h2>Informações do produto</h2>
      <p>As alterações serão refletidas imediatamente na loja.</p>
    </div>
  </div>
  <div class="admin-panel__body">
    <%= render "form", product: @product %>
  </div>
</section>
