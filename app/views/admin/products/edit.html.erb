<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-8">

      <div class="card shadow-sm">
        <div class="card-header">
          <h2 class="mb-0">Editar Produto</h2>
        </div>

        <div class="card-body">

          <% if @product.errors.any? %>
            <div class="alert alert-danger">
              <h5>
                <%= pluralize(@product.errors.count, "erro") %>
                impediram que o produto fosse salvo:
              </h5>

              <ul class="mb-0">
                <% @product.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <%= form_with(model: [:admin, @product], local: true) do |form| %>

            <div class="mb-4">
              <%= form.label :name, "Nome", class: "form-label fw-bold" %>
              <%= form.text_field :name,
                    class: "form-control" %>
            </div>

            <div class="mb-4">
              <%= form.label :description, "Descrição", class: "form-label fw-bold" %>
              <%= form.text_area :description,
                    rows: 5,
                    class: "form-control" %>
            </div>

            <div class="mb-4">
              <%= form.label :price, "Preço", class: "form-label fw-bold" %>
              <%= form.number_field :price,
                    step: 0.01,
                    class: "form-control" %>
            </div>

            <div class="mb-4">
              <%= form.label :image, "Imagem", class: "form-label fw-bold" %>
              <%= form.file_field :image,
                    class: "form-control" %>
            </div>

            <% if @product.image.attached? %>
              <div class="mb-4">
                <label class="form-label fw-bold">Imagem Atual</label>

                <div>
                  <%= image_tag @product.image,
                        class: "img-thumbnail",
                        style: "max-width: 250px;" %>
                </div>
              </div>
            <% end %>

            <div class="d-flex gap-2">
              <%= form.submit "Atualizar Produto",
                    class: "btn btn-primary" %>

              <%= link_to "Voltar",
                    admin_products_path,
                    class: "btn btn-outline-secondary" %>
            </div>

          <% end %>

        </div>
      </div>

    </div>
  </div>
</div>