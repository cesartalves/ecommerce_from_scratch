<% if product.errors.any? %>
  <div class="admin-form-errors" role="alert">
    <strong><%= pluralize(product.errors.count, "erro") %> impediram o salvamento:</strong>
    <ul>
      <% product.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: [:admin, product], local: true, class: "admin-form" do |form| %>
  <div class="admin-form-grid">
    <div class="admin-field admin-field--wide">
      <%= form.label :name, "Nome do produto" %>
      <%= form.text_field :name,
            required: true,
            autofocus: true,
            placeholder: "Ex.: Moeda comemorativa de prata" %>
      <small>Use um nome curto e fácil de identificar.</small>
    </div>

    <div class="admin-field admin-field--wide">
      <%= form.label :description, "Descrição" %>
      <%= form.text_area :description,
            rows: 6,
            placeholder: "Conte os detalhes, estado de conservação e história da peça." %>
    </div>

    <div class="admin-field">
      <%= form.label :price, "Preço" %>
      <div class="admin-money-input">
        <span>R$</span>
        <%= form.number_field :price, min: 0.01, step: 0.01, required: true, placeholder: "0,00" %>
      </div>
    </div>

    <div class="admin-field">
      <%= form.label :image, "Imagem" %>
      <%= form.file_field :image, accept: "image/png,image/jpeg,image/webp" %>
      <small>PNG, JPG ou WEBP.</small>
    </div>

    <div class="admin-field">
      <%= form.label :stock, "Estoque" %>
      <%= form.number_field :stock, min: 0, step: 1, required: true, placeholder: "0" %>
      <small>Quantidade disponível para venda.</small>
    </div>

    <div class="admin-field admin-field--wide">
      <div>
        <strong>Dados para cálculo do frete</strong>
        <small>Informe o peso do produto e as medidas da embalagem individual.</small>
      </div>
    </div>

    <div class="admin-field">
      <%= form.label :weight_grams, "Peso (gramas)" %>
      <%= form.number_field :weight_grams, min: 1, step: 1, required: true, placeholder: "300" %>
    </div>

    <div class="admin-field">
      <%= form.label :length_cm, "Comprimento (cm)" %>
      <%= form.number_field :length_cm, min: 0.01, step: 0.01, required: true, placeholder: "20" %>
    </div>

    <div class="admin-field">
      <%= form.label :width_cm, "Largura (cm)" %>
      <%= form.number_field :width_cm, min: 0.01, step: 0.01, required: true, placeholder: "15" %>
    </div>

    <div class="admin-field">
      <%= form.label :height_cm, "Altura (cm)" %>
      <%= form.number_field :height_cm, min: 0.01, step: 0.01, required: true, placeholder: "5" %>
    </div>
  </div>

  <% if product.image.attached? %>
    <div class="admin-current-image">
      <%= image_tag product.image, alt: product.name %>
      <div>
        <strong>Imagem atual</strong>
        <small>Envie um novo arquivo apenas se quiser substituí-la.</small>
      </div>
    </div>
  <% end %>

  <div class="admin-form-actions">
    <%= form.submit product.persisted? ? "Salvar alterações" : "Cadastrar produto",
          class: "admin-button admin-button--primary" %>
    <%= link_to "Cancelar", admin_products_path, class: "admin-button admin-button--secondary" %>
  </div>
<% end %>
